      "@id": "allianz:image",
      "@type": "xsd:string"
    },
    "status": {
      "@id": "allianz:status",
      "@type": "xsd:string"
    },
    "strategy": {
      "@id": "allianz:strategy",
      "@type": "xsd:string"
    },
    "deployedAt": {
      "@id": "allianz:deployed_at",
      "@type": "xsd:dateTime"
    },
    "deployedBy": {
      "@id": "allianz:deployed_by",
