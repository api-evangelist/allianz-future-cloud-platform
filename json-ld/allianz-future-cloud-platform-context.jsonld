    },
    "memoryUtilization": {
      "@id": "allianz:memory_utilization",
      "@type": "xsd:double"
    },
    "requestRate": {
      "@id": "allianz:request_rate",
      "@type": "xsd:double"
    },
    "errorRate": {
      "@id": "allianz:error_rate",
      "@type": "xsd:double"
    },
    "p99LatencyMs": {
      "@id": "allianz:p99_latency_ms",
      "@type": "xsd:integer"
    },
    "resourceId": {
      "@id": "allianz:resource_id",
      "@type": "xsd:string"
    },
    "resourceType": {
      "@id": "allianz:resource_type",
      "@type": "xsd:string"
    },
    "name": {
      "@id": "allianz:name",
      "@type": "xsd:string"
    },
    "namespace": {
      "@id": "allianz:namespace",
      "@type": "xsd:string"
    },
