      "@id": "allianz:created_at",
      "@type": "xsd:dateTime"
    },
    "total": {
      "@id": "allianz:total",
      "@type": "xsd:integer"
    },
    "items": {
      "@id": "allianz:items",
      "@container": "@set",
      "@type": "xsd:string"
    },
    "cpu": {
      "@id": "allianz:cpu",
      "@type": "xsd:string"
    },
    "memory": {
      "@id": "allianz:memory",
      "@type": "xsd:string"
    },
